# Base URL the frontend prepends to every API call (see src/lib/api.ts).
# Baked in at BUILD time by Vite — you must rebuild after changing it.
#   - Same-origin production (Nginx serves the app AND proxies /api): leave EMPTY
#     so requests become relative "/api/..." on the current domain.
#   - Split hosting (API on a different origin): set the full base, e.g.
#     https://api.yourdomain.com   (no trailing slash)
#   - Local dev against the backend on port 3000: http://localhost:3000
VITE_API_URL=

# Clerk publishable key (pk_test_... in dev, pk_live_... in production).
VITE_CLERK_PUBLISHABLE_KEY=
