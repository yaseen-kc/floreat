{
  "name": "@floreat/shared",
  "version": "0.0.0",
  "description": "Shared contracts, calculations, wire-format types and unit/Decimal helpers used by the Floreat frontend and backend.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./calc": {
      "types": "./dist/calc/index.d.ts",
      "default": "./dist/calc/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./units": {
      "types": "./dist/units/index.d.ts",
      "default": "./dist/units/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
