// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Jobs owned by this user. `Job.userId` references `clerkId` (the app-wide
  // "userId" is the Clerk id, matching request.userId), not the cuid `id`.
  jobs Job[]
}

model Job {
  id String @id @default(cuid())

  // Owner — stores the Clerk user id (request.userId). References User.clerkId,
  // so services filter jobs directly by request.userId with no extra lookup.
  // A local User row must exist first (provisioned by syncUser on job create).
  userId String
  user   User   @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  projectNo                String   @db.VarChar(50)
  subject                  String
  refNo                    String   @db.VarChar(50)
  date                     DateTime @db.Date
  designedByName           String
  designedByMobile         String   @db.VarChar(20)
  clientName               String?
  estimationEngineerName   String?
  estimationEngineerMobile String?  @db.VarChar(20)
  headOfSalesName          String?
  headOfSalesMobile        String?  @db.VarChar(20)
  firmName                 String?
  // Free-text (open-ended) fields, rendered as text inputs in the UI — not a
  // fixed set, so intentionally kept as String rather than enums.
  buildingUsage            String
  numberOfBuilding         Int
  frameType                String
  configuration            String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  roof        Roof?
  mezzanine   Mezzanine?
  stair       Stair?
  canopy      Canopy?
  load        Load?
  accessories Accessories?

  @@index([userId])
  @@index([userId, createdAt])
}

// ── Enums ─────────────────────────────────────────

enum SideWallSide {
  FRONT
  BACK
  RIGHT
  LEFT
}

enum PlateMaterialGrade {
  FE_345 @map("FE 345")
  FE_250 @map("FE 250")
  FE_400 @map("FE 400")
}

enum PurlinMaterialType {
  Z_C  @map("Z/C")
  TUBE
}

enum TypeOfWindBracing {
  ROD
  TUBE
}

enum TypeOfWall {
  BRICK
  PANEL
  LATERITE
  AAC
  BLOCK
}

enum CoveringType {
  BARE_GALVALUME @map("Bare Galvalume")
  PPGL           @map("PPGL")
  PUFF_SHEET     @map("Puff Sheet")
  OTHER          @map("Other")
}

enum RoofFrameBaseFixing {
  FOUNDATION_BOLT            @map("FOUNDATION BOLT")
  ANCHOR_BOLT                @map("ANCHOR BOLT")
  JOINT_BOLT_ON_STEEL_COLUMN @map("JOINT BOLT ON STEEL COLUMN")
}

model Roof {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // ── Core dimensions ──────────────────────────────────────────
  buildingOverallLength            Decimal @db.Decimal(10, 3)
  buildingOverallWidth             Decimal @db.Decimal(10, 3)
  eaveHeight                       Decimal @db.Decimal(10, 3)
  roofSlope                        Decimal @db.Decimal(10, 3)
  mainRoofFrames                   Int
  endRoofFrames                    Int
  roofPurlinSpacing                Decimal @db.Decimal(10, 3)
  claddingPurlins                  Int
  internalColumnsForMainRoofFrames Int
  internalColumnsForEndRoofFrames  Int

  // ── Members ──────────────────────────────────
  columnSegmentsInMainFrame   Int?
  raftersInOneHalfOfMainFrame Int?
  columnSegmentsInEndFrame    Int?
  raftersInOneHalfOfEndFrame  Int?
  endFrameHorizontalTieBeam   Int?

  // ── Purlin ───────────────────────────────────
  roofPurlinType           PurlinMaterialType?
  roofPurlinDepth          Decimal?            @db.Decimal(10, 3)
  roofPurlinUnitWeight     Decimal?            @db.Decimal(10, 3)
  claddingPurlinType       PurlinMaterialType?
  claddingPurlinDepth      Decimal?            @db.Decimal(10, 3)
  claddingPurlinUnitWeight Decimal?            @db.Decimal(10, 3)

  // ── Covering ───────────────────────────────
  roofCoveringType          CoveringType?
  roofCoveringThickness     Decimal?      @db.Decimal(10, 3)
  claddingCoveringType      CoveringType?
  claddingCoveringThickness Decimal?      @db.Decimal(10, 3)
  roofAreaDeduction         Decimal?      @db.Decimal(10, 3)

  // ── Flange Brace ───────────────────────
  roofFlangeBraceAverageLength     Decimal? @db.Decimal(10, 3)
  claddingFlangeBraceAverageLength Decimal? @db.Decimal(10, 3)
  endFrameFlangeBraceAverageLength Decimal? @db.Decimal(10, 3)

  // ── Polycarbonate ────────────────────
  polycarbonateRoofLength Decimal? @db.Decimal(10, 3)
  polycarbonateRoofWidth  Decimal? @db.Decimal(10, 3)
  polycarbonateRoofCount  Int?

  // ── Wind Bracing ───────────────────────
  roofWindBracingSegmentsInOneHalf Int?
  columnWindBracingSegments        Int?
  roofWindBracingProvidedBays      Int?
  columnWindBracingProvidedBays    Int?
  windBracingColumnHeight          Decimal?           @db.Decimal(10, 3)
  windBracingUnitWeight            Decimal?           @db.Decimal(10, 3)
  roofWindBracingBaySpacing        Decimal?           @db.Decimal(10, 3)
  columnWindBracingBaySpacing      Decimal?           @db.Decimal(10, 3)
  roofWindBracingLength            Decimal?           @db.Decimal(10, 3)
  columnWindBracingLength          Decimal?           @db.Decimal(10, 3)
  windBracingType                  TypeOfWindBracing?

  // ── Cladding Opening (ex RoofCladdingOpening) ───────────────
  frontCladdingOpeningArea Decimal? @db.Decimal(10, 3)
  backCladdingOpeningArea  Decimal? @db.Decimal(10, 3)
  rightCladdingOpeningArea Decimal? @db.Decimal(10, 3)
  leftCladdingOpeningArea  Decimal? @db.Decimal(10, 3)

  // ── Fascia Board (ex RoofFasciaBoard) ───────────────────────
  fasciaBoardArea             Decimal? @db.Decimal(10, 3)
  fasciaMaterialWeightPerSqft Decimal? @db.Decimal(10, 3)

  // ── Side Extension (ex RoofSideExtension) ───────────────────
  roofExtensionWidthHeight       Decimal? @db.Decimal(10, 3)
  roofExtensionMidFrameCount     Int?
  roofExtensionEndFrameCount     Int?
  claddingExtensionWidthHeight   Decimal? @db.Decimal(10, 3)
  claddingExtensionMidFrameCount Int?
  claddingExtensionEndFrameCount Int?
  sideColumnsWidthHeight         Decimal? @db.Decimal(10, 3)
  sideColumnsMidFrameCount       Int?
  sideColumnsEndFrameCount       Int?

  // ── Material Strength ──────
  gradeOfPlateMaterial PlateMaterialGrade?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Only real 1-to-many stays separate ──────────────────────
  sidewalls Sidewall[]

  // Base Fixing — nullable so partial/draft roofs can be saved before this is
  // chosen (consistent with every other optional Roof field).
  roofFrameBaseFixing RoofFrameBaseFixing?

  // Material Consumption
  materialConsumptionExcludingPurlin Decimal? @db.Decimal(10, 3)

  // SAG Rod
  diaOfRoofSagRod     Decimal? @db.Decimal(10, 3)
  diaOfCladdingSagRod Decimal? @db.Decimal(10, 3)

  @@index([createdAt])
}

model Sidewall {
  id        String       @id @default(cuid())
  roofId    String
  roof      Roof         @relation(fields: [roofId], references: [id], onDelete: Cascade)
  side      SideWallSide
  wallType  TypeOfWall
  thickness Decimal      @db.Decimal(10, 3)
  height    Decimal      @db.Decimal(10, 3)

  @@unique([roofId, side])
}

// ── Mezzanine Enums ───────────────────────────────

enum MezzanineType {
  DECK_SHEET   @map("DECK SHEET")
  FOLDED_PLATE @map("FOLDED PLATE")
  PANEL
  BOARD
  RCC_SLAB     @map("RCC SLAB")
}

enum MezzanineFloorLevel {
  FLOOR_1  @map("1st Floor")
  FLOOR_2  @map("2nd Floor")
  FLOOR_3  @map("3rd Floor")
  FLOOR_4  @map("4th Floor")
  FLOOR_5  @map("5th Floor")
  FLOOR_6  @map("6th Floor")
  FLOOR_7  @map("7th Floor")
  FLOOR_8  @map("8th Floor")
  FLOOR_9  @map("9th Floor")
  FLOOR_10 @map("10th Floor")
}

enum MezzanineHeightFrom {
  GROUND      @map("Ground")
  FIRST_FLOOR @map("First Floor")
  FLOOR_2     @map("2nd Floor")
  FLOOR_3     @map("3rd Floor")
  FLOOR_4     @map("4th Floor")
  FLOOR_5     @map("5th Floor")
}

// ── Mezzanine Models ──────────────────────────────

model Mezzanine {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floors     MezzanineFloor[]
  extensions MezzanineFloorExtension[]

  @@index([createdAt])
}

model MezzanineFloor {
  id          String    @id @default(cuid())
  mezzanineId String
  mezzanine   Mezzanine @relation(fields: [mezzanineId], references: [id], onDelete: Cascade)

  code       String?
  floor      MezzanineFloorLevel?
  type       MezzanineType?
  heightFrom MezzanineHeightFrom?

  // ── Dimensions ──
  thicknessMm                  Decimal? @db.Decimal(10, 3)
  lengthM                      Decimal? @db.Decimal(10, 3)
  widthM                       Decimal? @db.Decimal(10, 3)
  heightM                      Decimal? @db.Decimal(10, 3)
  materialConsumptionKgPerSqft Decimal? @db.Decimal(10, 3)

  // ── Beams ──
  beamsMidPrimary Int?
  beamsEndPrimary Int?
  beamsSecondary  Int?

  // ── Joints in beams ──
  jointsMidPrimary Int?
  jointsEndPrimary Int?

  // ── Internal columns ──
  internalColumnsMidPrimary Int?
  internalColumnsEndPrimary Int?

  // `code` is nullable to allow draft floors; the composite unique therefore
  // only constrains rows that have a code (Postgres treats NULLs as distinct).
  @@unique([mezzanineId, code])
}

model MezzanineFloorExtension {
  id          String    @id @default(cuid())
  mezzanineId String
  mezzanine   Mezzanine @relation(fields: [mezzanineId], references: [id], onDelete: Cascade)

  floor      MezzanineFloorLevel?
  type       MezzanineType?
  heightFrom MezzanineHeightFrom?
  typicalTo  MezzanineFloorLevel?

  // ── Dimensions ──
  thicknessMm Decimal? @db.Decimal(10, 3)
  lengthM     Decimal? @db.Decimal(10, 3)
  widthM      Decimal? @db.Decimal(10, 3)
  heightM     Decimal? @db.Decimal(10, 3)

  // ── Beams ──
  beamsMidPrimary Int?
  beamsEndPrimary Int?
  beamsSecondary  Int?

  // ── Joints in beams ──
  jointsMidPrimary Int?
  jointsEndPrimary Int?

  // ── Extended columns ──
  extendedColumnsMidPrimary Int?
  extendedColumnsEndPrimary Int?

  @@index([mezzanineId])
}

// ── Stair Enums ───────────────────────────────────

enum StairStepType {
  CHQ_PLATE_6MM @map("6MM CHQ PLATE")
  CHQ_PLATE_4MM @map("4MM CHQ PLATE")
  TUBE
}

enum StairFloorLevel {
  GROUND       @map("GROUND")
  FIRST_FLOOR  @map("FIRST FLOOR")
  SECOND_FLOOR @map("SECOND FLOOR")
  THIRD_FLOOR  @map("THIRD FLOOR")
  FOURTH_FLOOR @map("FOURTH FLOOR")
  FIFTH_FLOOR  @map("FIFTH FLOOR")
  SIXTH_FLOOR  @map("SIXTH FLOOR")
}

enum StairStringerType {
  HR_SECTION  @map("HR SECTION")
  FAB_SECTION @map("FAB SECTION")
}

enum AreaDeductionType {
  LIFT
  DUCT
  CUT_OUT @map("CUT-OUT")
}

enum AreaDeductionFor {
  STRUCTURE_DEDUCTION @map("STRUCTURE DEDUCTION")
  COVERING_DEDUCTION  @map("COVERING DEDUCTION")
  BOTH
}

// ── Stair Models ──────────────────────────────────

model Stair {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stairs         StairItem[]
  areaDeductions AreaDeduction[]

  @@index([createdAt])
}

model StairItem {
  id      String @id @default(cuid())
  stairId String
  stair   Stair  @relation(fields: [stairId], references: [id], onDelete: Cascade)

  code         String?
  typeOfStep   StairStepType?
  location     String?
  startingFrom StairFloorLevel?
  endingUpTo   StairFloorLevel?

  // ── Dimensions ──
  length Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)
  height Decimal? @db.Decimal(10, 3)

  numberOfMidLanding   Int?
  typeOfStringer       StairStringerType?
  unitWeightOfStringer Decimal?           @db.Decimal(10, 3)

  @@unique([stairId, code])
}

model AreaDeduction {
  id      String @id @default(cuid())
  stairId String
  stair   Stair  @relation(fields: [stairId], references: [id], onDelete: Cascade)

  type         AreaDeductionType?
  location     String?
  areaM2       Decimal?           @db.Decimal(10, 3)
  numbers      Int?
  deductionFor AreaDeductionFor?

  @@index([stairId])
}

// ── Canopy Enums ──────────────────────────────────

enum CanopyHeightFrom {
  GROUND
  FF
  SF
  FLOOR_3 @map("3rd Floor")
  FLOOR_4 @map("4th Floor")
  FLOOR_5 @map("5th Floor")
}

enum CanopySheetType {
  NCGL
  PPGL
  PUFF  @map("Puff")
  OTHER @map("Other")
}

// ── Canopy Models ─────────────────────────────────

model Canopy {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canopies CanopyItem[]

  @@index([createdAt])
}

model CanopyItem {
  id       String @id @default(cuid())
  canopyId String
  canopy   Canopy @relation(fields: [canopyId], references: [id], onDelete: Cascade)

  code       String?
  heightFrom CanopyHeightFrom?

  // ── Dimensions ──
  length                       Decimal? @db.Decimal(10, 3)
  width                        Decimal? @db.Decimal(10, 3)
  height                       Decimal? @db.Decimal(10, 3)
  materialConsumptionKgPerSqft Decimal? @db.Decimal(10, 3)

  // ── Members ──
  numberOfBeams      Int?
  numberOfPurlins    Int?
  purlinDepth        Decimal? @db.Decimal(10, 3)
  unitWeightOfPurlin Decimal? @db.Decimal(10, 3)

  // ── Covering ──
  canopySheet              CanopySheetType?
  sheetThick               Decimal?         @db.Decimal(10, 3)
  canopySideCoveringHeight Decimal?         @db.Decimal(10, 3)

  // ── Accessories ──
  gutter   Boolean?
  downTake Boolean?
  flashing Boolean?

  // `code` is nullable to allow draft items; the composite unique therefore
  // only constrains rows that have a code (Postgres treats NULLs as distinct).
  @@unique([canopyId, code])
}

// ── Load Enums ────────────────────────────────────

enum ApprovalDrawingsTimeUnit {
  DAYS
  WEEKS
  MONTHS
}

// ── Load Model ────────────────────────────────────

model Load {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // ── Load details (units implied: KN/M²; wind = KMPH) ──
  deadLoadOnRoofRafters       Decimal? @db.Decimal(10, 3)
  liveLoadOnRoofRafters       Decimal? @db.Decimal(10, 3)
  collateralLoadOnRoofRafters Decimal? @db.Decimal(10, 3)
  windLoadOnRoofRaftersUpward Decimal? @db.Decimal(10, 3) // KMPH
  windLoadHorizontal          Decimal? @db.Decimal(10, 3) // KMPH
  deadLoadOnRoofFloor         Decimal? @db.Decimal(10, 3)
  liveLoadOnRoofFloor         Decimal? @db.Decimal(10, 3)
  floorDeadLoad               Decimal? @db.Decimal(10, 3)
  floorFinishLoad             Decimal? @db.Decimal(10, 3)
  floorLiveLoad               Decimal? @db.Decimal(10, 3)
  snowLoad                    Decimal? @db.Decimal(10, 3)
  earthquakeLoad              Decimal? @db.Decimal(10, 3)

  // ── Completion period ──
  approvalDrawingsTime    Int?
  approvalDrawingsUnit    ApprovalDrawingsTimeUnit?
  supplyOfMaterialsDays   Int?
  erectionOfStructureDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

// ── Accessories Enums ─────────────────────────────

enum DrainageMaterial {
  PPGL
  UPVC
  ALUMINIUM
  GI
  COPPER
  TIN
}

enum DrainageSize {
  IN_4  @map("4 inches")
  IN_6  @map("6 inches")
  IN_8  @map("8 inches")
  IN_10 @map("10 inches")
  IN_12 @map("12 inches")
  IN_18 @map("18 inches")
  IN_24 @map("24 inches")
}

enum FlashingType {
  PPGL
  NCGL
  GI
}

enum FlashingThickness {
  MM_0_30 @map("0.30 MM")
  MM_0_35 @map("0.35 MM")
  MM_0_40 @map("0.40 MM")
  MM_0_45 @map("0.45 MM")
  MM_0_47 @map("0.47 MM")
  MM_0_50 @map("0.50 MM")
  MM_0_55 @map("0.55 MM")
  MM_0_80 @map("0.80 MM")
  MM_1_00 @map("1.00 MM")
  MM_1_20 @map("1.20 MM")
  MM_1_60 @map("1.60 MM")
  MM_1_80 @map("1.80 MM")
  MM_2_00 @map("2.00 MM")
}

enum PartitionType {
  AEROCON_PANEL @map("AEROCON PANEL")
  CEMENT_BOARD  @map("CEMENT BOARD")
  PPGL_SHEET    @map("PPGL SHEET")
  PUFF_SHEET    @map("PUFF SHEET")
  PLY_BOARD     @map("PLY BOARD")
}

enum PartitionThickness {
  MM_0_40 @map("0.40 MM")
  MM_0_45 @map("0.45 MM")
  MM_0_47 @map("0.47 MM")
  MM_6    @map("6 MM")
  MM_8    @map("8 MM")
  MM_12   @map("12 MM")
  MM_16   @map("16 MM")
  MM_18   @map("18 MM")
  MM_30   @map("30 MM")
  MM_40   @map("40 MM")
  MM_50   @map("50 MM")
  MM_75   @map("75 MM")
}

enum InsulationType {
  XLPE
  ROCK_WOOL        @map("ROCK WOOL")
  GLASS_WOOL       @map("GLASS WOOL")
  ALUMINIUM_BUBBLE @map("ALUMINIUM BUBBLE")
  COOL_BOARD       @map("COOL BOARD")
}

enum TurboVentilatorDiameter {
  IN_6  @map("6 Inches")
  FT_1  @map("1 Foot")
  IN_18 @map("18 Inches")
  FT_2  @map("2 Feet")
}

enum AccessoryOpeningKind {
  ROLLING_SHUTTER
  LOUVER
  SKY_LIGHT
  WALL_LIGHT
}

enum PaintType {
  EPOXY_PRIMER @map("EPOXY PRIMER")
  EPOXY_PAINT  @map("EPOXY PAINT")
}

enum PurlinsGirtsFinish {
  PRE_GALVANISED @map("PRE-GALVANISED")
}

enum PurlinsGirtsPaint {
  UNPAINTED
  PAINTED
}

enum FoundationBoltFinish {
  BLACK_UNPAINTED @map("BLACK (UNPAINTED)")
}

// ── Accessories Models ────────────────────────────

model Accessories {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // ── Gutter ──
  gutterType     DrainageMaterial?
  gutterSize     DrainageSize?
  gutterQuantity Int?

  // ── Down Take ──
  downTakeType     DrainageMaterial?
  downTakeSize     DrainageSize?
  downTakeQuantity Int?

  // ── Drip Trim ──
  dripTrimType      FlashingType?
  dripTrimThickness FlashingThickness?
  dripTrimQuantity  Int?

  // ── Gable End Flashing ──
  gableEndFlashingType      FlashingType?
  gableEndFlashingThickness FlashingThickness?
  gableEndFlashingQuantity  Int?

  // ── Corner Flash ──
  cornerFlashType      FlashingType?
  cornerFlashThickness FlashingThickness?
  cornerFlashQuantity  Int?

  // ── Ridge ──
  ridgeType      FlashingType?
  ridgeThickness FlashingThickness?
  ridgeQuantity  Int?

  // ── Partition ──
  partitionType      PartitionType?
  partitionThickness PartitionThickness?
  partitionQuantity  Int?

  // ── Insulation ──
  roofInsulationType InsulationType?
  wallInsulationType InsulationType?

  // ── Turbo Ventilator ──
  turboVentilatorDiameter TurboVentilatorDiameter?
  turboVentilatorNos      Int?

  // ── Handrail ──
  handrailWeightKg Decimal? @db.Decimal(10, 3)

  // ── Feature toggles ──
  deckSheetFlashingEnabled Boolean?
  gantryGirderEnabled      Boolean?
  liftStructureEnabled     Boolean?

  // ── Paint & Primer: Frames ──
  framesPrimerCoats Int?
  framesPrimerType  PaintType?
  framesPaintCoats  Int?
  framesPaintType   PaintType?

  // ── Paint & Primer: Purlins & Girts ──
  purlinsGirtsFinish PurlinsGirtsFinish?
  purlinsGirtsGsm    Int?
  purlinsGirtsPaint  PurlinsGirtsPaint?

  // ── Paint & Primer: Foundation Bolt ──
  foundationBoltFinish FoundationBoltFinish?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Openings (rolling shutters, louvers, sky lights, wall lights) ──
  openings AccessoryOpening[]

  // ── Line items ──
  doors        AccessoryDoor[]
  windows      AccessoryWindow[]
  foldedPlates AccessoryFoldedPlate[]

  @@index([createdAt])
}

model AccessoryDoor {
  id            String      @id @default(cuid())
  accessoriesId String
  accessories   Accessories @relation(fields: [accessoriesId], references: [id], onDelete: Cascade)

  // ── Dimensions ──
  height Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)

  nos      Int?
  quantity Int?

  @@index([accessoriesId])
}

model AccessoryWindow {
  id            String      @id @default(cuid())
  accessoriesId String
  accessories   Accessories @relation(fields: [accessoriesId], references: [id], onDelete: Cascade)

  // ── Dimensions ──
  height Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)

  nos      Int?
  quantity Int?

  @@index([accessoriesId])
}

model AccessoryFoldedPlate {
  id            String      @id @default(cuid())
  accessoriesId String
  accessories   Accessories @relation(fields: [accessoriesId], references: [id], onDelete: Cascade)

  // ── Dimensions ──
  length Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)

  nos      Int?
  quantity Int?

  @@index([accessoriesId])
}

model AccessoryOpening {
  id            String      @id @default(cuid())
  accessoriesId String
  accessories   Accessories @relation(fields: [accessoriesId], references: [id], onDelete: Cascade)

  kind AccessoryOpeningKind

  // ── Dimensions ──
  length Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)

  nos      Int?
  quantity Int?

  @@index([accessoriesId])
}
