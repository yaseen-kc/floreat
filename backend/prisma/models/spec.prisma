model Spec {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products SpecProduct[]

  @@index([createdAt])
}

model SpecProduct {
  id     String @id @default(cuid())
  specId String
  spec   Spec   @relation(fields: [specId], references: [id], onDelete: Cascade)

  code             String?
  description      String?
  specification    String?
  makeOrBrand      String?
  yieldStrengthMpa Int?

  // `code` is nullable to allow draft items; the composite unique therefore
  // only constrains rows that have a code (Postgres treats NULLs as distinct).
  @@unique([specId, code])
}
