model Spec {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  description      String?
  specifications   String[]
  makeOrBrand      String[]
  yieldStrengthMpa Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
}
