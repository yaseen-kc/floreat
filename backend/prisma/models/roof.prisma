// ── Enums ─────────────────────────────────────────

enum SideWallSide {
  FRONT
  BACK
  RIGHT
  LEFT
}

enum PlateMaterialGrade {
  FE_345 @map("FE 345")
  FE_250 @map("FE 250")
  FE_400 @map("FE 400")
}

enum PurlinMaterialType {
  Z_C  @map("Z/C")
  TUBE
}

enum TypeOfWindBracing {
  ROD
  TUBE
}

enum TypeOfWall {
  BRICK
  PANEL
  LATERITE
  AAC
  BLOCK
}

enum CoveringType {
  BARE_GALVALUME @map("Bare Galvalume")
  PPGL           @map("PPGL")
  PUFF_SHEET     @map("Puff Sheet")
  OTHER          @map("Other")
}

enum RoofFrameBaseFixing {
  FOUNDATION_BOLT            @map("FOUNDATION BOLT")
  ANCHOR_BOLT                @map("ANCHOR BOLT")
  JOINT_BOLT_ON_STEEL_COLUMN @map("JOINT BOLT ON STEEL COLUMN")
}

model Roof {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // ── Core dimensions ──────────────────────────────────────────
  buildingOverallLength            Decimal @db.Decimal(10, 3)
  buildingOverallWidth             Decimal @db.Decimal(10, 3)
  eaveHeight                       Decimal @db.Decimal(10, 3)
  roofSlope                        Decimal @db.Decimal(10, 3)
  mainRoofFrames                   Int
  endRoofFrames                    Int
  roofPurlinSpacing                Decimal @db.Decimal(10, 3)
  claddingPurlins                  Int
  internalColumnsForMainRoofFrames Int
  internalColumnsForEndRoofFrames  Int

  // ── Members ──────────────────────────────────
  columnSegmentsInMainFrame   Int?
  raftersInOneHalfOfMainFrame Int?
  columnSegmentsInEndFrame    Int?
  raftersInOneHalfOfEndFrame  Int?
  endFrameHorizontalTieBeam   Int?

  // ── Purlin ───────────────────────────────────
  roofPurlinType           PurlinMaterialType?
  roofPurlinDepth          Decimal?            @db.Decimal(10, 3)
  roofPurlinUnitWeight     Decimal?            @db.Decimal(10, 3)
  claddingPurlinType       PurlinMaterialType?
  claddingPurlinDepth      Decimal?            @db.Decimal(10, 3)
  claddingPurlinUnitWeight Decimal?            @db.Decimal(10, 3)

  // ── Covering ───────────────────────────────
  roofCoveringType          CoveringType?
  roofCoveringThickness     Decimal?      @db.Decimal(10, 3)
  claddingCoveringType      CoveringType?
  claddingCoveringThickness Decimal?      @db.Decimal(10, 3)
  roofAreaDeduction         Decimal?      @db.Decimal(10, 3)

  // ── Flange Brace ───────────────────────
  roofFlangeBraceAverageLength     Decimal? @db.Decimal(10, 3)
  claddingFlangeBraceAverageLength Decimal? @db.Decimal(10, 3)
  endFrameFlangeBraceAverageLength Decimal? @db.Decimal(10, 3)

  // ── Polycarbonate ────────────────────
  polycarbonateRoofLength Decimal? @db.Decimal(10, 3)
  polycarbonateRoofWidth  Decimal? @db.Decimal(10, 3)
  polycarbonateRoofCount  Int?

  // ── Wind Bracing ───────────────────────
  roofWindBracingSegmentsInOneHalf Int?
  columnWindBracingSegments        Int?
  roofWindBracingProvidedBays      Int?
  columnWindBracingProvidedBays    Int?
  windBracingColumnHeight          Decimal?           @db.Decimal(10, 3)
  windBracingUnitWeight            Decimal?           @db.Decimal(10, 3)
  roofWindBracingBaySpacing        Decimal?           @db.Decimal(10, 3)
  columnWindBracingBaySpacing      Decimal?           @db.Decimal(10, 3)
  roofWindBracingLength            Decimal?           @db.Decimal(10, 3)
  columnWindBracingLength          Decimal?           @db.Decimal(10, 3)
  windBracingType                  TypeOfWindBracing?

  // ── Cladding Opening (ex RoofCladdingOpening) ───────────────
  frontCladdingOpeningArea Decimal? @db.Decimal(10, 3)
  backCladdingOpeningArea  Decimal? @db.Decimal(10, 3)
  rightCladdingOpeningArea Decimal? @db.Decimal(10, 3)
  leftCladdingOpeningArea  Decimal? @db.Decimal(10, 3)

  // ── Fascia Board (ex RoofFasciaBoard) ───────────────────────
  fasciaBoardArea             Decimal? @db.Decimal(10, 3)
  fasciaMaterialWeightPerSqft Decimal? @db.Decimal(10, 3)

  // ── Side Extension (ex RoofSideExtension) ───────────────────
  roofExtensionWidthHeight       Decimal? @db.Decimal(10, 3)
  roofExtensionMidFrameCount     Int?
  roofExtensionEndFrameCount     Int?
  claddingExtensionWidthHeight   Decimal? @db.Decimal(10, 3)
  claddingExtensionMidFrameCount Int?
  claddingExtensionEndFrameCount Int?
  sideColumnsWidthHeight         Decimal? @db.Decimal(10, 3)
  sideColumnsMidFrameCount       Int?
  sideColumnsEndFrameCount       Int?

  // ── Material Strength ──────
  gradeOfPlateMaterial PlateMaterialGrade?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Only real 1-to-many stays separate ──────────────────────
  sidewalls Sidewall[]

  // Base Fixing — nullable so partial/draft roofs can be saved before this is
  // chosen (consistent with every other optional Roof field).
  roofFrameBaseFixing RoofFrameBaseFixing?

  // Material Consumption
  materialConsumptionExcludingPurlin Decimal? @db.Decimal(10, 3)

  // SAG Rod
  diaOfRoofSagRod     Decimal? @db.Decimal(10, 3)
  diaOfCladdingSagRod Decimal? @db.Decimal(10, 3)

  @@index([createdAt])
}

model Sidewall {
  id        String       @id @default(cuid())
  roofId    String
  roof      Roof         @relation(fields: [roofId], references: [id], onDelete: Cascade)
  side      SideWallSide
  wallType  TypeOfWall
  thickness Decimal      @db.Decimal(10, 3)
  height    Decimal      @db.Decimal(10, 3)

  @@unique([roofId, side])
}
