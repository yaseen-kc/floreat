// ── Accessories Enums ─────────────────────────────

enum DrainageMaterial {
  PPGL
  UPVC
  ALUMINIUM
  GI
  COPPER
  TIN
}

enum DrainageSize {
  IN_4  @map("4 inches")
  IN_6  @map("6 inches")
  IN_8  @map("8 inches")
  IN_10 @map("10 inches")
  IN_12 @map("12 inches")
  IN_18 @map("18 inches")
  IN_24 @map("24 inches")
}

enum FlashingType {
  PPGL
  NCGL
  GI
}

enum FlashingThickness {
  MM_0_30 @map("0.30 MM")
  MM_0_35 @map("0.35 MM")
  MM_0_40 @map("0.40 MM")
  MM_0_45 @map("0.45 MM")
  MM_0_47 @map("0.47 MM")
  MM_0_50 @map("0.50 MM")
  MM_0_55 @map("0.55 MM")
  MM_0_80 @map("0.80 MM")
  MM_1_00 @map("1.00 MM")
  MM_1_20 @map("1.20 MM")
  MM_1_60 @map("1.60 MM")
  MM_1_80 @map("1.80 MM")
  MM_2_00 @map("2.00 MM")
}

enum PartitionType {
  AEROCON_PANEL @map("AEROCON PANEL")
  CEMENT_BOARD  @map("CEMENT BOARD")
  PPGL_SHEET    @map("PPGL SHEET")
  PUFF_SHEET    @map("PUFF SHEET")
  PLY_BOARD     @map("PLY BOARD")
}

enum PartitionThickness {
  MM_0_40 @map("0.40 MM")
  MM_0_45 @map("0.45 MM")
  MM_0_47 @map("0.47 MM")
  MM_6    @map("6 MM")
  MM_8    @map("8 MM")
  MM_12   @map("12 MM")
  MM_16   @map("16 MM")
  MM_18   @map("18 MM")
  MM_30   @map("30 MM")
  MM_40   @map("40 MM")
  MM_50   @map("50 MM")
  MM_75   @map("75 MM")
}

enum InsulationType {
  XLPE
  ROCK_WOOL        @map("ROCK WOOL")
  GLASS_WOOL       @map("GLASS WOOL")
  ALUMINIUM_BUBBLE @map("ALUMINIUM BUBBLE")
  COOL_BOARD       @map("COOL BOARD")
}

enum TurboVentilatorDiameter {
  IN_6  @map("6 Inches")
  FT_1  @map("1 Foot")
  IN_18 @map("18 Inches")
  FT_2  @map("2 Feet")
}

enum PaintType {
  EPOXY_PRIMER @map("EPOXY PRIMER")
  EPOXY_PAINT  @map("EPOXY PAINT")
}

enum PurlinsGirtsFinish {
  PRE_GALVANISED @map("PRE-GALVANISED")
}

enum PurlinsGirtsPaint {
  UNPAINTED
  PAINTED
}

enum FoundationBoltFinish {
  BLACK_UNPAINTED @map("BLACK (UNPAINTED)")
}

// ── Accessories Models ────────────────────────────

model Accessories {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // ── Gutter ──
  gutterType           DrainageMaterial?
  gutterSize           DrainageSize?
  // Server-derived quantities (see @floreat/shared/calc deriveAccessoryQuantities):
  // computed from the job's Roof. Each column has a companion `*Manual` flag: when
  // true the client's value is kept and the roof-driven recompute leaves it alone;
  // when false (default) the value is server-derived and any client value ignored.
  // Decimal to preserve the fractional results of the flashing equations.
  gutterQuantity       Decimal?          @db.Decimal(10, 3)
  gutterQuantityManual Boolean           @default(false)

  // ── Down Take ──
  downTakeType           DrainageMaterial?
  downTakeSize           DrainageSize?
  downTakeQuantity       Decimal?          @db.Decimal(10, 3)
  downTakeQuantityManual Boolean           @default(false)

  // ── Drip Trim ──
  dripTrimType           FlashingType?
  dripTrimThickness      FlashingThickness?
  dripTrimQuantity       Decimal?           @db.Decimal(10, 3)
  dripTrimQuantityManual Boolean            @default(false)

  // ── Gable End Flashing ──
  gableEndFlashingType           FlashingType?
  gableEndFlashingThickness      FlashingThickness?
  gableEndFlashingQuantity       Decimal?           @db.Decimal(10, 3)
  gableEndFlashingQuantityManual Boolean            @default(false)

  // ── Corner Flash ──
  cornerFlashType           FlashingType?
  cornerFlashThickness      FlashingThickness?
  cornerFlashQuantity       Decimal?           @db.Decimal(10, 3)
  cornerFlashQuantityManual Boolean            @default(false)

  // ── Ridge ──
  ridgeType           FlashingType?
  ridgeThickness      FlashingThickness?
  ridgeQuantity       Decimal?           @db.Decimal(10, 3)
  ridgeQuantityManual Boolean            @default(false)

  // ── Partition ──
  partitionType      PartitionType?
  partitionThickness PartitionThickness?
  partitionQuantity  Int?

  // ── Openings ──
  rollingShutterLength   Decimal? @db.Decimal(10, 3)
  rollingShutterWidth    Decimal? @db.Decimal(10, 3)
  rollingShutterNos      Int?
  rollingShutterQuantity Decimal? @db.Decimal(10, 3)

  louverLength   Decimal? @db.Decimal(10, 3)
  louverWidth    Decimal? @db.Decimal(10, 3)
  louverNos      Int?
  louverQuantity Decimal? @db.Decimal(10, 3)

  skyLightLength   Decimal? @db.Decimal(10, 3)
  skyLightWidth    Decimal? @db.Decimal(10, 3)
  skyLightNos      Int?
  skyLightQuantity Decimal? @db.Decimal(10, 3)

  wallLightLength   Decimal? @db.Decimal(10, 3)
  wallLightWidth    Decimal? @db.Decimal(10, 3)
  wallLightNos      Int?
  wallLightQuantity Decimal? @db.Decimal(10, 3)

  // ── Insulation ──
  roofInsulationType InsulationType?
  wallInsulationType InsulationType?

  // ── Turbo Ventilator ──
  turboVentilatorDiameter TurboVentilatorDiameter?
  turboVentilatorNos      Int?

  // ── Handrail ──
  handrailWeightKg Decimal? @db.Decimal(10, 3)

  // ── Feature toggles ──
  deckSheetFlashingEnabled Boolean?
  gantryGirderEnabled      Boolean?
  liftStructureEnabled     Boolean?

  // ── Paint & Primer: Frames ──
  framesPrimerCoats Int?
  framesPrimerType  PaintType?
  framesPaintCoats  Int?
  framesPaintType   PaintType?

  // ── Paint & Primer: Purlins & Girts ──
  purlinsGirtsFinish PurlinsGirtsFinish?
  purlinsGirtsGsm    Int?
  purlinsGirtsPaint  PurlinsGirtsPaint?

  // ── Paint & Primer: Foundation Bolt ──
  foundationBoltFinish FoundationBoltFinish?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Doors, Windows, Folded Plates ──
  doorHeight   Decimal? @db.Decimal(10, 3)
  doorWidth    Decimal? @db.Decimal(10, 3)
  doorNos      Int?
  doorQuantity Decimal? @db.Decimal(10, 3)

  windowHeight   Decimal? @db.Decimal(10, 3)
  windowWidth    Decimal? @db.Decimal(10, 3)
  windowNos      Int?
  windowQuantity Decimal? @db.Decimal(10, 3)

  foldedPlateLength   Decimal? @db.Decimal(10, 3)
  foldedPlateWidth    Decimal? @db.Decimal(10, 3)
  foldedPlateNos      Int?
  foldedPlateQuantity Decimal? @db.Decimal(10, 3)

  @@index([createdAt])
}


