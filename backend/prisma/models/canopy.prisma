// ── Canopy Enums ──────────────────────────────────

enum CanopyCode {
  CANOPY_1  @map("CANOPY-1")
  CANOPY_2  @map("CANOPY-2")
  CANOPY_3  @map("CANOPY-3")
  CANOPY_4  @map("CANOPY-4")
  CANOPY_5  @map("CANOPY-5")
  CANOPY_6  @map("CANOPY-6")
  CANOPY_7  @map("CANOPY-7")
  CANOPY_8  @map("CANOPY-8")
  CANOPY_9  @map("CANOPY-9")
  CANOPY_10 @map("CANOPY-10")
}

enum CanopyHeightFrom {
  GROUND
  FF
  SF
  FLOOR_3 @map("3rd Floor")
  FLOOR_4 @map("4th Floor")
  FLOOR_5 @map("5th Floor")
}

enum CanopySheetType {
  NCGL
  PPGL
  PUFF  @map("Puff")
  OTHER @map("Other")
}

// ── Canopy Models ─────────────────────────────────

model Canopy {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canopies CanopyItem[]

  @@index([createdAt])
}

model CanopyItem {
  id       String @id @default(cuid())
  canopyId String
  canopy   Canopy @relation(fields: [canopyId], references: [id], onDelete: Cascade)

  code       CanopyCode?
  heightFrom CanopyHeightFrom?

  // ── Dimensions ──
  length                       Decimal? @db.Decimal(10, 3)
  width                        Decimal? @db.Decimal(10, 3)
  height                       Decimal? @db.Decimal(10, 3)
  materialConsumptionKgPerSqft Decimal? @db.Decimal(10, 3)

  // ── Members ──
  numberOfBeams      Int?
  numberOfPurlins    Int?
  purlinDepth        Decimal? @db.Decimal(10, 3)
  unitWeightOfPurlin Decimal? @db.Decimal(10, 3)

  // ── Covering ──
  canopySheet              CanopySheetType?
  sheetThick               Decimal?         @db.Decimal(10, 3)
  canopySideCoveringHeight Decimal?         @db.Decimal(10, 3)

  // ── Accessories ──
  gutter   Boolean?
  downTake Boolean?
  flashing Boolean?

  // `code` is nullable to allow draft items; the composite unique therefore
  // only constrains rows that have a code (Postgres treats NULLs as distinct).
  @@unique([canopyId, code])
}
