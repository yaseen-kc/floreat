    purlinBoltsExtendedFrames           Int?
    purlinBoltsBoltsPerPurlinJoint      Int?

    // roofJointBolts
    roofJointBoltsSpecification String?
    roofJointBoltsUnit          QuantityUnit?
    roofJointBoltsQuantity      Decimal?      @db.Decimal(10, 3)

    // foundationBolts
    foundationBoltsSpecification String?
    foundationBoltsUnit          QuantityUnit?
    foundationBoltsQuantity      Decimal?      @db.Decimal(10, 3)

    // anchorBolts
    anchorBoltsSpecification String?
    anchorBoltsUnit          QuantityUnit?
    anchorBoltsQuantity      Decimal?      @db.Decimal(10, 3)
}

