    // raftersAndColumns
    raftersAndColumnsSpecification           String?
    raftersAndColumnsUnit                    QuantityUnit?
    raftersAndColumnsQuantity                Decimal?      @db.Decimal(10, 3)
    raftersAndColumnsAdditionalQuantity      Decimal?      @db.Decimal(10, 3)
    raftersAndColumnsBuildingLength          Decimal?      @db.Decimal(10, 3)
    raftersAndColumnsBuildingLengthUnit      QuantityUnit?
    raftersAndColumnsInclinedLengthOneHalf   Decimal?      @db.Decimal(10, 3)
    raftersAndColumnsInclinedLengthUnit      QuantityUnit?
    raftersAndColumnsRoofArea                Decimal?      @db.Decimal(10, 3)
    raftersAndColumnsRoofAreaUnit            QuantityUnit?
    raftersAndColumnsMaterialConsumption     Decimal?      @db.Decimal(10, 3)
    raftersAndColumnsMaterialConsumptionUnit QuantityUnit?

    // roofPurlins
    roofPurlinesValue                 Decimal? // Condition Value
    roofPurlinsSpecification          String?
    roofPurlinsUnit                   QuantityUnit?
    roofPurlinsQuantity               Decimal?      @db.Decimal(10, 3)
    roofPurlinsAdditionalQuantity     Decimal?      @db.Decimal(10, 3)
    roofPurlinsSinglePurlinLength     Decimal?      @db.Decimal(10, 3)
    roofPurlinsSinglePurlinLengthUnit QuantityUnit?
    roofPurlinsPurlinsPerFrame        Int?
    roofPurlinsTotalPurlinBays        Int?
    roofPurlinsPurlinUnitWeight       Decimal?      @db.Decimal(10, 3)
    roofPurlinsPurlinUnitWeightUnit   QuantityUnit?
    roofPurlinsExtendedFramePurlins   Int?
    roofPurlinsExtendedPurlinBays     Int?

    // roofSheet
    roofSheetSpecification                  String?
    roofSheetUnit                           QuantityUnit?
    roofSheetQuantity                       Decimal?      @db.Decimal(10, 3)
    roofSheetPurchaseQuantity               Decimal?      @db.Decimal(10, 3)
    roofSheetAdditionalQuantity             Decimal?      @db.Decimal(10, 3)
    roofSheetExtendedRoofWidth              Decimal?      @db.Decimal(10, 3)
    roofSheetExtendedRoofWidthUnit          QuantityUnit?
    roofSheetExtendedRoofLength             Decimal?      @db.Decimal(10, 3)
    roofSheetExtendedRoofLengthUnit         QuantityUnit?
    roofSheetRoofAreaDeductions             Decimal?      @db.Decimal(10, 3)
    roofSheetRoofAreaDeductionsUnit         QuantityUnit?
    roofSheetPolycarbonateAreaDeduction     Decimal?      @db.Decimal(10, 3)
    roofSheetPolycarbonateAreaDeductionUnit QuantityUnit?

    // polycarbonateSheet
    polycarbonateSheetUnit               QuantityUnit?
    polycarbonateSheetQuantity           Decimal?      @db.Decimal(10, 3)
    polycarbonateSheetPurchaseQuantity   Decimal?      @db.Decimal(10, 3)
    polycarbonateSheetAdditionalQuantity Decimal?      @db.Decimal(10, 3)
    polycarbonateSheetSheetLength        Decimal?      @db.Decimal(10, 3)
    polycarbonateSheetSheetLengthUnit    QuantityUnit?
    polycarbonateSheetSheetWidth         Decimal?      @db.Decimal(10, 3)
    polycarbonateSheetSheetWidthUnit     QuantityUnit?
    polycarbonateSheetNumberOfSheets     Int?

    // roofWindBracings
    roofWindBracingsUnit                    QuantityUnit?
    roofWindBracingsQuantity                Decimal?      @db.Decimal(10, 3)
    roofWindBracingsAdditionalQuantity      Decimal?      @db.Decimal(10, 3)
    roofWindBracingsSingleBracingLength     Decimal?      @db.Decimal(10, 3)
    roofWindBracingsSingleBracingLengthUnit QuantityUnit?
    roofWindBracingsTotalBracings           Int?
    roofWindBracingsUnitWeight              Decimal?      @db.Decimal(10, 3)
    roofWindBracingsUnitWeightUnit          QuantityUnit?

    // roofSagRod
    roofSagRodValue                  Decimal? // Condition Value
    roofSagRodUnit                   QuantityUnit?
    roofSagRodQuantity               Decimal?      @db.Decimal(10, 3)
    roofSagRodAdditionalQuantity     Decimal?      @db.Decimal(10, 3)
    roofSagRodSingleSagRodLength     Decimal?      @db.Decimal(10, 3)
    roofSagRodSingleSagRodLengthUnit QuantityUnit?
    roofSagRodSagRodsPerFrame        Int?
    roofSagRodSagRodBays             Int?
    roofSagRodExtendedFrameSagRods   Int?
    roofSagRodExtendedSagRodBays     Int?
    roofSagRodUnitWeight             Decimal?      @db.Decimal(10, 3)
    roofSagRodUnitWeightUnit         QuantityUnit?

    // roofFlangeBrace
    roofFlangeBraceUnit                    QuantityUnit?
    roofFlangeBraceQuantity                Decimal?      @db.Decimal(10, 3)
    roofFlangeBraceAdditionalQuantity      Decimal?      @db.Decimal(10, 3)
    roofFlangeBraceMidFrameBraceLength     Decimal?      @db.Decimal(10, 3)
    roofFlangeBraceMidFrameBraceLengthUnit QuantityUnit?
    roofFlangeBraceMidFrameBraces          Int?
    roofFlangeBraceEndFrameBraces          Int?
    roofFlangeBraceMidFrames               Int?
    roofFlangeBraceEndFrames               Int?
    roofFlangeBraceExtendedFrameMidBraces  Int?
    roofFlangeBraceExtendedFrameEndBraces  Int?
    roofFlangeBraceExtendedMidFrames       Int?
    roofFlangeBraceExtendedEndFrames       Int?
    roofFlangeBraceEndFrameBraceLength     Decimal?      @db.Decimal(10, 3)
