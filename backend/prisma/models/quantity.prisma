  quantityId String   @unique
  quantity   Quantity @relation(fields: [quantityId], references: [id], onDelete: Cascade)

  doors                            Decimal? @db.Decimal(10, 3)
  doorsQuantity                    Decimal? @db.Decimal(10, 3)
  windows                          Decimal? @db.Decimal(10, 3)
  windowsQuantity                  Decimal? @db.Decimal(10, 3)
  fasciaStructureQuantity          Decimal? @db.Decimal(10, 3)
  fasciaCoveringSheetBoardQuantity Decimal? @db.Decimal(10, 3)
  internalPartitionsQuantity       Decimal? @db.Decimal(10, 3)
  ridgeQuantity                    Decimal? @db.Decimal(10, 3)
  gutterQuantity                   Decimal? @db.Decimal(10, 3)
  downtakeQuantity                 Decimal? @db.Decimal(10, 3)
  dripTrimQuantity                 Decimal? @db.Decimal(10, 3)
  gableEndFlashingQuantity         Decimal? @db.Decimal(10, 3)
  cornerFlashQuantity              Decimal? @db.Decimal(10, 3)
  rollingShutter                   Decimal? @db.Decimal(10, 3)
  rollingShutterQuantity           Decimal? @db.Decimal(10, 3)
  louvers                          Decimal? @db.Decimal(10, 3)
  louversQuantity                  Decimal? @db.Decimal(10, 3)
  skyLight                         Decimal? @db.Decimal(10, 3)
  skyLightQuantity                 Decimal? @db.Decimal(10, 3)
  wallLight                        Decimal? @db.Decimal(10, 3)
  wallLightQuantity                Decimal? @db.Decimal(10, 3)
  roofInsulation                   Decimal? @db.Decimal(10, 3)
  roofInsulationQuantity           Decimal? @db.Decimal(10, 3)
  wallInsulation                   Decimal? @db.Decimal(10, 3)
  wallInsulationQuantity           Decimal? @db.Decimal(10, 3)
  turboVentilatorsQuantity         Decimal? @db.Decimal(10, 3)
  handrailQuantity                 Decimal? @db.Decimal(10, 3)
}

model QuantityMezzanine {
  id         String   @id @default(cuid())
  quantityId String   @unique
  quantity   Quantity @relation(fields: [quantityId], references: [id], onDelete: Cascade)

  mezzanineStructureQuantity   Decimal? @db.Decimal(10, 3)
  totalMezzanineArea           Decimal? @db.Decimal(10, 3)
  totalMezzanineAreaQuantity   Decimal? @db.Decimal(10, 3)
  materialConsumption          Decimal? @db.Decimal(10, 3)
  deckSheetQuantity            Decimal? @db.Decimal(10, 3)
  deckSheetPurchaseQuantity    Decimal? @db.Decimal(10, 3)
  deckSheetQuantityAdditional  Decimal? @db.Decimal(10, 3)
  shearStudsQuantity           Decimal? @db.Decimal(10, 3)
  shearStudsQuantityAdditional Decimal? @db.Decimal(10, 3)
  concreteFlashing             Decimal? @db.Decimal(10, 3)
  jointBolts                   Decimal? @db.Decimal(10, 3)
  jointBoltsQuantity           Decimal? @db.Decimal(10, 3)
  foundationBoltsQuantity      Decimal? @db.Decimal(10, 3)
}

model QuantityStair {
  id         String   @id @default(cuid())
  quantityId String   @unique
  quantity   Quantity @relation(fields: [quantityId], references: [id], onDelete: Cascade)

  totalAreaOfStairQuantity             Decimal? @db.Decimal(10, 3)
  totalWeightofStringerBeams           Decimal? @db.Decimal(10, 3)
  totalWeightofStringerBeamsQuantity   Decimal? @db.Decimal(10, 3)
  totalWeightofStringerBeamsAdditional Decimal? @db.Decimal(10, 3)
  totalWeightofSteps                   Decimal? @db.Decimal(10, 3)
  totalWeightofStepsQuantity           Decimal? @db.Decimal(10, 3)
  totalWeightofStepsAdditional         Decimal? @db.Decimal(10, 3)
}

model QuantityAdditionalBolts {
  id         String   @id @default(cuid())
  quantityId String   @unique
  quantity   Quantity @relation(fields: [quantityId], references: [id], onDelete: Cascade)

  jointBolt1Quantity     Decimal? @db.Decimal(10, 3)
  jointBolt2Quantity     Decimal? @db.Decimal(10, 3)
  jointBolt3Quantity     Decimal? @db.Decimal(10, 3)
  purlinBoltQuantity     Decimal? @db.Decimal(10, 3)
  anchorBoltQuantity     Decimal? @db.Decimal(10, 3)
  foundationBoltQuantity Decimal? @db.Decimal(10, 3)
}
