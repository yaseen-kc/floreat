    // purlinBolts
    purlinBoltsSpecification            String?
    purlinBoltsUnit                     QuantityUnit?
    purlinBoltsQuantity                 Decimal?      @db.Decimal(10, 3)
    purlinBoltsPurlinJointsPerFrame     Int?
    purlinBoltsTotalFrames              Int?
